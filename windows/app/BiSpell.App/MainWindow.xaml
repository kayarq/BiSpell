<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BiSpell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BiSpell"
    xmlns:models="using:BiSpell.Models"
    xmlns:services="using:BiSpell.Services"
    Title="BiSpell — Notes">

    <Grid x:Name="RootGrid" Padding="12" RowSpacing="10" ColumnSpacing="10"
          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
          KeyDown="RootGrid_KeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" MinWidth="160"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Header + toolbar + settings (span all columns) -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="4" Spacing="8">
            <TextBlock Text="BiSpell" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="Notes + TR/EN spelling (in-app only). No system-wide hotkey or UIA injection."
                       Opacity="0.7" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="CheckButton" Content="Check (F7)" Click="CheckButton_Click"
                        Style="{StaticResource AccentButtonStyle}" MinWidth="120"/>
                <Button x:Name="ApplyButton" Content="Apply" Click="ApplyButton_Click"
                        IsEnabled="False" MinWidth="88"/>
                <Button x:Name="AddDictButton" Content="Add to dictionary" Click="AddDictButton_Click"
                        IsEnabled="False"/>
                <Button x:Name="IgnoreButton" Content="Ignore" Click="IgnoreButton_Click"
                        IsEnabled="False"/>
                <Button x:Name="SaveNoteButton" Content="Save (Ctrl+S)" Click="SaveNoteButton_Click"
                        MinWidth="120"/>
            </StackPanel>

            <!-- Daily-use settings card (saved to %APPDATA%\BiSpell\settings.json).
                 Structure only: no IsChecked / Checked / Unchecked / Value / ValueChanged here.
                 State + handlers are applied in MainWindow code-behind after InitializeComponent
                 + LoadSettingsIntoUi (W1 — avoids ToggleButton.IsChecked assign crash). -->
            <Border Padding="12,10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="6"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Spell settings"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock x:Name="SettingsPathHint"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Opacity="0.65"
                               TextWrapping="Wrap"
                               Text="Saved to %APPDATA%\BiSpell\settings.json"/>

                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <CheckBox x:Name="EnabledCheck" Content="Spell-check enabled"/>
                        <CheckBox x:Name="TurkishCheck" Content="Turkish"/>
                        <CheckBox x:Name="EnglishCheck" Content="English"/>
                        <CheckBox x:Name="AsYouTypeCheck" Content="As-you-type check"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="Max suggestions" VerticalAlignment="Center"/>
                            <NumberBox x:Name="MaxSuggestionsBox"
                                       Minimum="1"
                                       Maximum="20"
                                       SpinButtonPlacementMode="Inline"
                                       SmallChange="1"
                                       LargeChange="5"
                                       Width="120"/>
                        </StackPanel>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Min word length" VerticalAlignment="Center"/>
                                <NumberBox x:Name="MinWordLengthBox"
                                           Minimum="1"
                                           Maximum="10"
                                           SpinButtonPlacementMode="Inline"
                                           SmallChange="1"
                                           LargeChange="1"
                                           Width="100"/>
                            </StackPanel>
                            <TextBlock Text="Tokens shorter than this are skipped when checking."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Opacity="0.65"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Debounce (ms)" VerticalAlignment="Center"/>
                                <NumberBox x:Name="DebounceBox"
                                           Minimum="0"
                                           Maximum="5000"
                                           SpinButtonPlacementMode="Inline"
                                           SmallChange="50"
                                           LargeChange="250"
                                           Width="120"/>
                            </StackPanel>
                            <TextBlock Text="Applies after typing pause / after delete settle."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Opacity="0.65"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Notes sidebar -->
        <Grid Grid.Row="1" Grid.Column="0" RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Notes" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6">
                <Button x:Name="NewNoteButton" Content="New" Click="NewNoteButton_Click"
                        MinWidth="64"/>
                <Button x:Name="DeleteNoteButton" Content="Delete" Click="DeleteNoteButton_Click"
                        MinWidth="72" IsEnabled="False"/>
            </StackPanel>
            <ListView x:Name="NotesList"
                      Grid.Row="2"
                      SelectionMode="Single"
                      SelectionChanged="NotesList_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="services:NoteItem">
                        <StackPanel Padding="4,6" Spacing="2">
                            <TextBlock Text="{x:Bind Title}" TextWrapping="WrapNoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind FileName}" Opacity="0.55" FontSize="11"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Note editor -->
        <Grid Grid.Row="1" Grid.Column="1" RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="EditorHeader"
                       Text="Note"
                       Style="{StaticResource SubtitleTextBlockStyle}"/>
            <TextBox x:Name="EditorBox"
                     Grid.Row="1"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     PlaceholderText="Write a note… first line becomes the title"
                     FontFamily="Segoe UI"
                     FontSize="15"/>
        </Grid>

        <!-- Misspellings -->
        <Grid Grid.Row="1" Grid.Column="2" RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Misspellings" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <ListView x:Name="MisspellingsList"
                      Grid.Row="1"
                      SelectionChanged="MisspellingsList_SelectionChanged"
                      DoubleTapped="MisspellingsList_DoubleTapped">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:MisspellingItem">
                        <StackPanel Padding="4,6" Spacing="2">
                            <TextBlock Text="{x:Bind Display}" TextWrapping="Wrap"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind RangeLabel}" Opacity="0.6" FontSize="12"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Suggestions -->
        <Grid Grid.Row="1" Grid.Column="3" RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Suggestions (Enter / double-click apply)"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       TextWrapping="Wrap"/>
            <ListView x:Name="SuggestionsList"
                      Grid.Row="1"
                      SelectionChanged="SuggestionsList_SelectionChanged"
                      DoubleTapped="SuggestionsList_DoubleTapped"
                      KeyDown="SuggestionsList_KeyDown"/>
        </Grid>

        <!-- Lexicon management: collapsible -->
        <Expander x:Name="LexiconExpander"
                  Grid.Row="2" Grid.ColumnSpan="4"
                  Header="Personal dictionary &amp; ignored words"
                  IsExpanded="False"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  VerticalAlignment="Stretch">
            <Grid Height="140" ColumnSpacing="12" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="AddedWordsHeader"
                               Text="Dictionary"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <ListView x:Name="AddedWordsList"
                              Grid.Row="1"
                              SelectionMode="Single"
                              SelectionChanged="AddedWordsList_SelectionChanged"/>
                    <Button x:Name="RemoveWordButton"
                            Grid.Row="2"
                            Content="Remove selected"
                            Click="RemoveWordButton_Click"
                            IsEnabled="False"
                            HorizontalAlignment="Left"
                            MinWidth="120"/>
                </Grid>

                <Grid Grid.Column="1" RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="IgnoredWordsHeader"
                               Text="Ignored"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <ListView x:Name="IgnoredWordsList"
                              Grid.Row="1"
                              SelectionMode="Single"
                              SelectionChanged="IgnoredWordsList_SelectionChanged"/>
                    <Button x:Name="UnignoreWordButton"
                            Grid.Row="2"
                            Content="Unignore selected"
                            Click="UnignoreWordButton_Click"
                            IsEnabled="False"
                            HorizontalAlignment="Left"
                            MinWidth="120"/>
                </Grid>
            </Grid>
        </Expander>

        <!-- Engine status / load error -->
        <InfoBar x:Name="ErrorBar"
                 Grid.Row="3" Grid.ColumnSpan="4"
                 IsOpen="False"
                 Severity="Error"
                 IsClosable="True"
                 Title="Engine error"/>

        <!-- Status line -->
        <Border Grid.Row="4" Grid.ColumnSpan="4"
                Padding="8,6"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="4"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Text="Ready — press F7 or Check to spell-check."
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="CountBadge"
                           Grid.Column="1"
                           Text="0 misspellings"
                           FontWeight="SemiBold"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
